GHOSTBOT_API_URL=https://your-ghostbot-domain.com/api/chat
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_BASE_URL=https://ghostai.solutions
NEXT_PUBLIC_GHOST_AVATAR_DEV_UI=0

# Security and auth
OAUTH_STATE_SECRET=change-this-oauth-state-secret
TOKEN_STORE_ENCRYPTION_KEY=change-this-token-store-key

# Admin dashboard auth
ADMIN_DASHBOARD_PASSWORD=change-this-admin-password
ADMIN_DASHBOARD_SESSION_SECRET=change-this-admin-session-secret

# Social Agent credentials
LINKEDIN_ACCESS_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# Optional legacy aliases still supported by current code
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_ORG_ID=
LINKEDIN_ORGANIZATION_URN=

# Meta (Facebook/Instagram) app integration
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=

# Vercel Cron auth secret (recommended single source of truth)
CRON_SECRET=change-this-cron-secret

# Railway orchestrator trigger secret (external scheduler auth)
RAILWAY_TRIGGER_SECRET=change-this-railway-trigger-secret

# Optional explicit base URL used by orchestrator internal calls
AUTOMATION_INTERNAL_BASE_URL=https://ghostai.solutions

# Preferred: GitHub App credentials for Content Agent repo writes
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
# Optional explicit repo targeting for Content Agent trigger
GITHUB_REPO_OWNER=burchdad
GITHUB_REPO_NAME=ghostaisolutions
GITHUB_TARGET_BRANCH=main

# Optional fallback for repo writes if GitHub App is not configured
GITHUB_TOKEN=

# Blog and trend feature flags
GENERATE_BLOG_IMAGES=false
PRODUCT_HUNT_TOKEN=

# Newsletter / outreach
RESEND_API_KEY=
RESEND_FROM_EMAIL=newsletter@ghostai.solutions
RESEND_REPLY_TO=
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO=
OUTREACH_SENDER_NAME=
OUTREACH_SENDER_ROLE=

# Leads controls
LEADS_OUTREACH_DAILY_CAP=30
LEADS_OUTREACH_COOLDOWN_HOURS=72

# Public verification tags (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Optional legacy fallback for manual trigger integrations
SOCIAL_AGENT_CRON_SECRET=change-this-social-cron-secret
